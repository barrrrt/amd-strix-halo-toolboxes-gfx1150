FROM barrrrt/amd-strix-halo-toolboxes-gfx1150:rocm7-nightlies AS builder

# 1. Build-Abhängigkeiten installieren (Fedora Style)
RUN dnf install -y \
    git \
    golang \
    cmake \
    gcc-c++ \
    clinfo \
    rocm-runtime-devel \
    rocm-hip-devel \
    hipblas-devel \
    rocblas-devel \
    && dnf clean all

# 2. Ollama Source holen
WORKDIR /build
RUN git clone --recursive https://github.com .

# 3. WICHTIG: Die Zielarchitektur für Strix Point setzen
# Wir fügen gfx1150 explizit zu den AMDGPU_TARGETS hinzu
ENV AMDGPU_TARGETS="gfx1150;gfx1100"
ENV CMAKE_ARGS="-DGGML_HIPBLAS=ON -DAMDGPU_TARGETS=gfx1150"

# 4. Ollama bauen
RUN go generate ./... \
    && go build .

# --- Finales Image ---
FROM barrrrt/amd-strix-halo-toolboxes-gfx1150:rocm7-nightlies

# Benötigte Laufzeit-Libs
RUN dnf install -y hipblas rocblas && dnf clean all

# Kopiere die selbstgebaute Binary vom Builder-Stage
COPY --from=builder /build/ollama /usr/local/bin/ollama

# Umgebungsvariablen für die Erkennung
ENV OLLAMA_HOST=0.0.0.0
ENV HSA_OVERRIDE_GFX_VERSION=11.5.0

ENTRYPOINT ["ollama", "serve"]
